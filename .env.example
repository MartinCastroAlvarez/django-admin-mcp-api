# Example environment file. Copy to `.env` (which is gitignored) and edit.
# Never commit a real .env. The repo's pre-commit hooks (gitleaks + the
# no-partial-tokens pygrep rule) will block any token-shaped string from
# entering version control.

# Optional: a settings module override for tests / local scripts.
# DJANGO_SETTINGS_MODULE=tests.test_project.settings

# Optional: enable verbose MCP wire logging in dev.
# DJANGO_ADMIN_MCP_DEBUG=0
